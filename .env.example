# OneNote MCP Server — environment example
# Copy to .env and fill in your values.

# --- Transport ---
# PORT=8000
# HOST=0.0.0.0

# --- Azure App Registration ---
# 1. Create an App Registration in the Azure Portal
# 2. "Expose an API" → add scope "mcp-access", set token version to 2
# 3. "Authentication" → add redirect URI (Web): http://localhost:8000/auth/callback
# 4. "Certificates & secrets" → create a client secret → paste below
# 5. "API permissions" → add delegated: Notes.Read, Notes.Read.All, User.Read, Group.Read.All
#    → Grant admin consent
# 6. "Authentication" → Allow public client flows = Yes

AZURE_CLIENT_ID=your-app-registration-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_TENANT_ID=your-tenant-id

# Base URL of this server (used for OAuth redirect URI construction)
MCP_BASE_URL=http://localhost:8000
